# =============================================================================
#  Secrets — never commit
# =============================================================================
# `.env` carries the Azure OpenAI key. `.env.example` is the safe template
# and IS committed (no leading dot-rule on the example itself).
.env
.env.local
.env.*.local
*.local
secrets/
*.key
*.pem
*.p12
*.crt

# =============================================================================
#  Bank-statement PDFs — PII, never commit
# =============================================================================
# Every PDF in this project is a real bank statement with real account
# numbers, names, addresses, and transactions. Block ALL .pdf files by
# default so accidental adds are impossible. Override per-file if you ever
# create a SYNTHETIC sample that's safe to publish, e.g.:
#     !samples/synthetic_example.pdf
*.pdf

# Per-debtor sample folders — ignored as wildcards so naming any specific
# debtor here doesn't itself leak PII (the directory names on disk carry
# real customer first names; this .gitignore is public on GitHub). Every
# file inside is real bank-statement or salary-slip PII for one customer.
mutasi_*/
slip_*/
# Internal credit-analysis sample bundle (generic name, no PII in itself).
sample_document_analisa_kredit/

# Generated / scratch outputs
out/
tmp/
*.log
*.json.bak

# ocr_slip per-request run artifacts + generated parser/UI output. These carry
# uploaded PDFs and extracted JSON with PII (names, salaries) — never commit.
runs/
output*/
web_output/

# =============================================================================
#  Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
build/
dist/
.eggs/
pip-wheel-metadata/
share/python-wheels/
MANIFEST

# Test / lint / type-check caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyre/
.pytype/
.tox/
.nox/

# Coverage
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
*.py,cover
nosetests.xml

# Jupyter (if anyone opens a notebook for ad-hoc inspection)
.ipynb_checkpoints/

# =============================================================================
#  Virtualenvs
# =============================================================================
.venv/
venv/
env/
ENV/
.python-version

# =============================================================================
#  IDE / editor / agent tooling
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project

# Claude Code & related tooling — these hold per-developer workspace state
# (settings.local.json, skill installs) and shouldn't be shared.
.claude/
.agents/
.qodo/
skills-lock.json

# =============================================================================
#  Operating system
# =============================================================================
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Unrelated sibling project (its own git repo)
salary-slip-parser-api/

# =============================================================================
#  Scratch / PII / large artifacts — never commit
# =============================================================================
# OCR diagnostic scratch — includes rendered crops of REAL KTP scans (PII).
_ocr_test/
# Bundled Tesseract language data (large, re-downloadable).
local_classifier/tessdata/
# Node / Next.js (belt-and-suspenders in case a sub-.gitignore is missing).
node_modules/
.next/
# Stray spreadsheet/CSV PII anywhere.
*.xlsx
*.csv
