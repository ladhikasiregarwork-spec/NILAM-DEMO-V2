# Copy this file to .env and fill in real values.
# Never commit .env.
# Loaded by local_classifier/classifier_app.py on startup (via python-dotenv).
# NOTE: the AZURE_* and OCR_ENDPOINT_URL / limits below are consumed by the
# LEGACY ocr_* packages (ocr_classifier, ocr_mutasi, ...), NOT by the active
# local_classifier on 8020. The active classifier classifies transactions with
# rule-based logic and reads OCR from PADDLE_OCR_URL.

# --- Remote OCR for the ACTIVE classifier (local_classifier, port 8020) ---
# When set, all OCR (KTP fragments, KK boxes, scanned slip/SK + classification)
# is sent to this /predict/json service instead of a local PaddleOCR install.
PADDLE_OCR_URL=
PADDLE_TIMEOUT=
# Falls back to OCR_API_KEY below if PADDLE_OCR_KEY is unset.
# PADDLE_OCR_KEY=

# --- Azure OpenAI (LLM for credit-transaction classification; legacy ocr_*) ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_DEPLOYMENT=

# --- Limits (legacy ocr_*) ---
LLM_REQUEST_TIMEOUT_S=
MAX_PDF_BYTES=

# --- PaddleOCR service used by the LEGACY ocr_* packages (markdown format) ---
OCR_ENDPOINT_URL=
OCR_API_KEY=
OCR_SKIP_ORIENTATION=
OCR_TIMEOUT_S=

# --- ocr_classifier limits (legacy ocr_*) ---
MAX_CLASSIFY_CHARS=
BATCH_OCR_CONCURRENCY=

# --- Tesseract ---
# Set to 1 to use the bundled Indonesian language data for Tesseract OCR.
# TESS_USE_IND=

# --- Service URLs (read by the Next.js /api proxy; defaults already correct) ---
# CLASSIFIER_URL=
# NPW_URL=

# Geolocation
GOOGLE_MAPS_API_KEY=
